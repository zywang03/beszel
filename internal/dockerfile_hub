FROM --platform=$BUILDPLATFORM golang:alpine AS builder

WORKDIR /app

# Download Go modules
COPY ../go.mod ../go.sum ./
RUN go env -w GOPROXY=https://goproxy.cn,direct
RUN go mod download

RUN apk add --no-cache \
    nodejs \
    npm \
    unzip \
    ca-certificates

RUN update-ca-certificates

# Install frontend dependencies first for better Docker layer reuse
COPY ./internal/site/package.json ./internal/site/package-lock.json ./internal/site/
RUN npm ci --prefix ./internal/site

# Copy source files
COPY . ./

# Build the frontend so embedded dist always matches the current source
RUN npm run --prefix ./internal/site build

# Build
ARG TARGETOS TARGETARCH
RUN CGO_ENABLED=0 GOGC=75 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -ldflags "-w -s" -o /beszel ./internal/cmd/hub

# ? -------------------------
FROM scratch

COPY --from=builder /beszel /
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/

# Ensure data persistence across container recreations
VOLUME ["/beszel_data"]

EXPOSE 8090

ENTRYPOINT [ "/beszel" ]
CMD ["serve", "--http=0.0.0.0:8090"]
